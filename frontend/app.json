{
  "expo": {
    "name": "Scambio di Favori",
    "slug": "scambio-di-favori",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-image.png",
    "scheme": "scambiodifavori",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.scambiodifavori",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Questa app usa la fotocamera per scansionare codici QR.",
        "NSPhotoLibraryUsageDescription": "Questa app accede alla libreria foto per la foto profilo.",
        "NSLocationWhenInUseUsageDescription": "Questa app usa la posizione per mostrare favori vicini."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-image.png",
        "backgroundColor": "#0F1A14"
      },
      "package": "com.emergent.scambiodifavori",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1A14"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Accesso alle foto per la foto profilo."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Per mostrare favori vicini."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "451c9e7f-fa11-4914-a8f0-7ff3d07cde8f"
      }
    }
  }
}

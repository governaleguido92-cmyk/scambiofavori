{
  "expo": {
    "name": "Scambio di Favori",
    "slug": "scambio-di-favori",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-image.png",
    "scheme": "scambiodifavori",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emergent.scambiodifavori",
      "buildNumber": "2",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Questa app usa la fotocamera per scansionare codici QR per completare i favori.",
        "NSPhotoLibraryUsageDescription": "Questa app accede alla libreria foto per impostare la foto del profilo.",
        "NSLocationWhenInUseUsageDescription": "Questa app usa la posizione per mostrare favori vicini a te.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["85F4.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-image.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.emergent.scambiodifavori",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1A14"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Questa app accede alla libreria foto per impostare la foto del profilo."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Questa app usa la posizione per mostrare favori vicini a te."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-image.png",
          "color": "#2D5A3D"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "451c9e7f-fa11-4914-a8f0-7ff3d07cde8f"
      }
    }
  }
}
